//@version=5
// bnb_bot — Volatility-Targeted Regime Momentum (single-symbol TradingView port)
//
// Faithful-ish port of the locked entry (bnb_bot/presets.py). Use on a DAILY chart.
// Long-only. The strategy is long only while ALL of these hold, else flat (cash):
//   * Regime gate:  close > 50-day SMA
//   * Momentum:     EMA(12) > EMA(26)
//   * DD breaker:   not currently >20% below the since-flat equity peak (blocks new entries)
// On entry it is sized by VOLATILITY: weight = min(maxWeight, targetVol / realised_daily_vol),
// so a calm market gets a bigger position than a wild one. It exits fully on signal-off
// or a 10% stop-loss.
//
// NOTE: it enters ONCE at the vol-sized weight and holds (no per-bar re-trimming). That
// keeps the order count sane AND mirrors the Python engine, whose 15% rebalance band
// means it rarely resizes mid-hold anyway.
//
// CAVEATS (why it won't match the Python backtest exactly):
//   - TradingView money-management / fill model differs slightly from our engine.
//   - Costs here are a flat 0.35% commission (swap + slippage); $0.30 gas/trade omitted.
//   - SINGLE-symbol; the Python headline also has a 4-token portfolio layer.
//   - Orders evaluate on bar close and fill at the NEXT bar's open (no lookahead).

strategy("bnb_bot — Vol-Targeted Regime Momentum", overlay=true,
     initial_capital=10000, currency=currency.USD,
     commission_type=strategy.commission.percent, commission_value=0.35,
     calc_on_every_tick=false, process_orders_on_close=false)

// === Inputs (locked-entry defaults) ===
trendLen  = input.int(50,    "Regime trend SMA length")
fastLen   = input.int(12,    "Momentum fast EMA")
slowLen   = input.int(26,    "Momentum slow EMA")
targetVol = input.float(0.015,"Target volatility (per day)", step=0.005)
volLen    = input.int(15,    "Volatility lookback (days)")
maxWeight = input.float(1.0, "Max weight (0..1)", step=0.1, minval=0.0, maxval=1.0)
stopFrac  = input.float(0.10,"Stop-loss fraction", step=0.01)
ddHalt    = input.float(0.20,"Drawdown breaker (fraction)", step=0.01)

// === Indicators ===
sma  = ta.sma(close, trendLen)
emaF = ta.ema(close, fastLen)
emaS = ta.ema(close, slowLen)
ret  = close / close[1] - 1.0
rvol = ta.stdev(ret, volLen)            // realised daily volatility

regimeOK   = close > sma
momentumOK = emaF > emaS
weight     = rvol > 0 ? math.min(maxWeight, targetVol / rvol) : maxWeight

// === Campaign equity peak (resets when flat) + drawdown breaker ===
var float campPeak = strategy.equity
isFlat = strategy.position_size == 0
campPeak := isFlat ? strategy.equity : math.max(campPeak, strategy.equity)
dd = campPeak > 0 ? (campPeak - strategy.equity) / campPeak : 0.0
breakerBlocks = dd >= ddHalt          // halt NEW entries during a deep drawdown

wantLong = regimeOK and momentumOK
stopHit  = strategy.position_size > 0 and close <= strategy.position_avg_price * (1.0 - stopFrac)

// === Orders: enter vol-sized once, exit fully on signal-off / stop ===
if strategy.position_size == 0 and wantLong and not breakerBlocks and close > 0
    qty = (weight * strategy.equity) / close
    strategy.entry("long", strategy.long, qty=qty)

if strategy.position_size > 0 and (not wantLong or stopHit)
    strategy.close("long")

// === Visuals ===
plot(sma,  "50-day trend", color=color.orange, linewidth=2)
plot(emaF, "EMA fast", color=color.new(color.blue, 60))
plot(emaS, "EMA slow", color=color.new(color.gray, 60))
bgcolor(strategy.position_size > 0 ? color.new(color.green, 88) : na, title="invested")
plot(weight, "vol-sized weight", color=color.green, display=display.data_window)
